rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboards/{courseId}/students/{userId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId}/settings/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Allow users to write their auth code/tokens
    // Read is allowed falsely because Server-Side Admin SDK bypasses this anyway
    // But we strictly deny client reads to be safe
    match /users/{userId}/private_tokens/{document=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if false; 
    }
  }
}
